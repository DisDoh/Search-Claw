# Discord application values
DISCORD_TOKEN=put_your_discord_bot_token_here
DISCORD_CLIENT_ID=put_your_discord_application_client_id_here

# Search Claw Python server
PY_AGENT_URL=http://127.0.0.1:8811/message
MAX_OPEN_PAGES=5

# Local OpenAI-compatible LLM server, usually llama.cpp server
LLAMA_BASE_URL=http://127.0.0.1:8033
LLAMA_MODEL=
LLAMA_TEMPERATURE=0.7
LLAMA_TOP_P=0.9
LLAMA_MAX_TOKENS=900

# Discord bridge behavior
CHAT_HISTORY_LIMIT=6
DISCORD_MAX_CHARS=1900
AXIOS_TIMEOUT=180000
REGISTER_COMMANDS=true
