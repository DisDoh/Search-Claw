# Local OpenAI-compatible LLM server, started by ./run_all.sh
LLAMA_BASE_URL=http://127.0.0.1:8033
LLAMA_MODEL=
LLAMA_TEMPERATURE=0.7
LLAMA_TOP_P=0.9
LLAMA_MAX_TOKENS=900

# llama.cpp launcher config
LLAMA_CPP_DIR=$HOME/llama.cpp
MODEL_PATH=$HOME/models/model.gguf
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8033
LLAMA_CTX=4096
LLAMA_NGL=0
LLAMA_BUILD_CUDA=false

# Search Claw Python HTTP server
SEARCH_CLAW_HOST=127.0.0.1
SEARCH_CLAW_PORT=8811
REQUIRE_SOURCES=true
# Optional fallback when DuckDuckGo returns 202/429 or blocks automated requests.
# Example for a local/private instance: SEARXNG_BASE_URL=http://127.0.0.1:8888
SEARXNG_BASE_URL=

# Discord bridge optional settings. Copy discord/.env.example to discord/.env too.
PY_AGENT_URL=http://127.0.0.1:8811/message
MAX_OPEN_PAGES=5
CHAT_HISTORY_LIMIT=6

# WhatsApp bridge prefixes
ENABLE_CHAT_PREFIX=true
CHAT_PREFIX=!
ENABLE_SEARCH_PREFIX=true
SEARCH_PREFIX=?
IGNORE_FROM_ME=false
IGNORE_GROUPS=true
WHATSAPP_MAX_CHARS=3500
